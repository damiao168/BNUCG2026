.login-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 80rpx 48rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #F8F6F0 0%, #E8E6E0 100%);
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 80rpx;
}

.logo-wrapper {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #7A9E9F 0%, #8B9A7D 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(122, 158, 159, 0.3);
  margin-bottom: 32rpx;
}

.logo-icon {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-text {
  font-size: 64rpx;
}

.app-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #4A4A4A;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.app-subtitle {
  font-size: 28rpx;
  color: #8A8A8A;
  letter-spacing: 2rpx;
}

.login-content {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.feature-list {
  width: 100%;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
  background-color: rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
}

.feature-icon {
  font-size: 36rpx;
  margin-right: 24rpx;
}

.feature-text {
  font-size: 30rpx;
  color: #4A4A4A;
}

.login-footer {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #7A9E9F 0%, #8B9A7D 100%);
  border-radius: 48rpx;
  border: none;
  padding: 0;
  margin: 0;
}

.secondary-btn {
  margin-top: 20rpx;
  background: #FFFFFF;
  border: 2rpx solid #D7D1C6;
}

.login-btn::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.secondary-text {
  color: #6D675E;
}

.secondary-icon {
  color: #6D675E;
}

.privacy-tips {
  display: flex;
  align-items: center;
  margin-top: 32rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #8A8A8A;
}

.tips-link {
  font-size: 24rpx;
  color: #7A9E9F;
}
