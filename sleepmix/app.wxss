page {
  background-color: #F8F6F0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #4A4A4A;
  line-height: 1.5;
}

.container {
  padding: 32rpx;
  box-sizing: border-box;
}

.text-primary {
  color: #4A4A4A;
}

.text-secondary {
  color: #8A8A8A;
}

.text-accent {
  color: #7A9E9F;
}

.bg-primary {
  background-color: #F8F6F0;
}

.bg-card {
  background-color: #E8E6E0;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}
