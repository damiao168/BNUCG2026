.audio-block {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #E8E6E0;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  transition: all 0.3s ease;
  opacity: 0.6;
}

.audio-block.enabled {
  opacity: 1;
  background-color: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.audio-block-left {
  margin-right: 24rpx;
}

.pattern-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(139, 154, 125, 0.1);
}

.pattern-svg {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.audio-block-right {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.audio-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.audio-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #4A4A4A;
}

.toggle-switch {
  width: 64rpx;
  height: 36rpx;
  border-radius: 18rpx;
  background-color: #CCCCCC;
  position: relative;
  transition: all 0.3s ease;
}

.toggle-switch.active {
  background-color: #7A9E9F;
}

.toggle-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background-color: #FFFFFF;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.toggle-switch.active .toggle-dot {
  left: 32rpx;
}

.audio-control {
  display: flex;
  align-items: center;
}

.ratio-slider {
  flex: 1;
  margin: 0;
}

.ratio-value {
  width: 80rpx;
  text-align: right;
  font-size: 26rpx;
  color: #8A8A8A;
  margin-left: 16rpx;
}
