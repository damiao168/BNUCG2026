.control-bar {
  padding: 32rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.control-buttons {
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-bottom: 24rpx;
}

.control-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 32rpx;
  border-radius: 16rpx;
  background-color: #F8F6F0;
  transition: all 0.3s ease;
}

.control-btn:active {
  transform: scale(0.95);
  background-color: #E8E6E0;
}

.btn-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.iconfont {
  font-size: 36rpx;
}

.btn-text {
  font-size: 24rpx;
  color: #4A4A4A;
}

.play-btn.playing {
  background-color: #7A9E9F;
}

.play-btn.playing .btn-text {
  color: #FFFFFF;
}

.play-btn.playing .iconfont {
  color: #FFFFFF;
}

.loop-btn.active {
  background-color: #8B9A7D;
}

.loop-btn.active .btn-text {
  color: #FFFFFF;
}

.loop-btn.active .iconfont {
  color: #FFFFFF;
}

.status-bar {
  text-align: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #E8E6E0;
}

.status-text {
  font-size: 26rpx;
  color: #8A8A8A;
}
