<view class="control-bar">
  <view class="control-buttons">
    <view class="control-btn play-btn {{isPlaying ? 'playing' : ''}}" bindtap="onPlay">
      <view class="btn-icon">
        <text class="iconfont" wx:if="{{isPlaying}}">⏸</text>
        <text class="iconfont" wx:else>▶</text>
      </view>
      <text class="btn-text" wx:if="{{isPlaying}}">暂停</text>
      <text class="btn-text" wx:else>播放</text>
    </view>

    <view class="control-btn random-btn" bindtap="onRandom">
      <view class="btn-icon">
        <text class="iconfont">✨</text>
      </view>
      <text class="btn-text">随机</text>
    </view>

    <view class="control-btn loop-btn {{isLooping ? 'active' : ''}}" bindtap="onLoop">
      <view class="btn-icon">
        <text class="iconfont">🔄</text>
      </view>
      <text class="btn-text">循环</text>
    </view>
  </view>

  <view class="status-bar">
    <text class="status-text" wx:if="{{activeCount > 0}}">已选择 {{activeCount}} 个音轨</text>
    <text class="status-text" wx:else>点击播放开始助眠</text>
  </view>
</view>
