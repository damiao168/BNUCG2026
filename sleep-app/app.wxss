page {
  --primary-color: #5A7D9A;
  --primary-color-dark: #243647;
  --success-color: #7CB89E;
  --success-color-dark: #5A9E7A;
  --bg-page: #FAFAFA;
  --bg-card: rgba(255, 255, 255, 0.85);
  --text-primary: #334155;
  --text-secondary: #64748B;
  --accent-color-1: #8D7B68;
  --accent-color-2: #C8A2C8;
  --shadow-card: 0 2rpx 8rpx rgba(90, 125, 154, 0.08);
  --border-color: rgba(90, 125, 154, 0.1);
  --overlay-bg: rgba(250, 250, 250, 0.9);
  --input-bg: rgba(255, 255, 255, 0.85);
  --input-border: rgba(90, 125, 154, 0.15);
  --warning-color: #C9A86C;
  --error-color: #B87D7D;
  --disabled-color: #CBD5E1;
  
  background-color: var(--bg-page);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  transition: background-color 0.3s ease, color 0.3s ease;
}

page.theme-dark,
.theme-dark {
  --bg-page: #1A202C;
  --bg-card: rgba(45, 55, 72, 0.7);
  --text-primary: #E2E8F0;
  --text-secondary: #94A3B8;
  --shadow-card: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  --border-color: rgba(255, 255, 255, 0.08);
  --overlay-bg: rgba(26, 32, 44, 0.9);
  --input-bg: rgba(45, 55, 72, 0.7);
  --input-border: rgba(255, 255, 255, 0.1);
  --disabled-color: #4A5568;
}

.container {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  background-color: var(--bg-page);
  transition: background-color 0.3s ease;
}

.page-container {
  min-height: 100vh;
  background-color: var(--bg-page);
  transition: background-color 0.3s ease;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 32rpx;
}

.card {
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(4rpx);
  transition: background 0.3s ease, box-shadow 0.3s ease;
}

.card-title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.btn-primary {
  background: var(--primary-color);
  color: #FFFFFF;
  border: none;
  border-radius: 44rpx;
  padding: 24rpx 48rpx;
  font-size: 36rpx;
  font-weight: 500;
  text-align: center;
  transition: all 0.2s ease;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-secondary {
  background: var(--bg-card);
  color: var(--text-secondary);
  border: none;
  border-radius: 44rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 400;
  text-align: center;
  transition: all 0.2s ease;
}

.btn-secondary:active {
  opacity: 0.85;
}

.text-primary {
  color: var(--text-primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-accent-1 {
  color: var(--accent-color-1);
}

.text-accent-2 {
  color: var(--accent-color-2);
}

.text-muted {
  color: var(--text-secondary);
}

.bg-primary {
  background-color: var(--primary-color);
}

.bg-accent-1 {
  background-color: var(--accent-color-1);
}

.bg-accent-2 {
  background-color: var(--accent-color-2);
}

.rounded {
  border-radius: 16rpx;
}

.rounded-lg {
  border-radius: 20rpx;
}

.rounded-full {
  border-radius: 50%;
}

.shadow {
  box-shadow: var(--shadow-card);
}

.flex {
  display: flex;
}

.flex-column {
  flex-direction: column;
}

.flex-wrap {
  flex-wrap: wrap;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

.justify-around {
  justify-content: space-around;
}

.align-center {
  align-items: center;
}

.flex-1 {
  flex: 1;
}

.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mt-40 { margin-top: 40rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.mb-40 { margin-bottom: 40rpx; }
.ml-10 { margin-left: 10rpx; }
.ml-20 { margin-left: 20rpx; }
.mr-10 { margin-right: 10rpx; }
.mr-20 { margin-right: 20rpx; }
.p-10 { padding: 10rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

.text-center { text-align: center; }
.text-left { text-align: left; }
.text-right { text-align: right; }

.overflow-hidden { overflow: hidden; }
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes fadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}

@keyframes scaleIn {
  from { transform: scale(0.95); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

@keyframes breathe {
  0%, 100% { transform: scale(1); opacity: 0.7; }
  50% { transform: scale(1.05); opacity: 1; }
}

.fade-in {
  animation: fadeIn 0.3s ease;
}

.fade-out {
  animation: fadeOut 0.3s ease;
}

.scale-in {
  animation: scaleIn 0.3s ease;
}

.breathe {
  animation: breathe 4s ease-in-out infinite;
}

.icon {
  width: 48rpx;
  height: 48rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.icon-sm {
  width: 36rpx;
  height: 36rpx;
}

.icon-lg {
  width: 64rpx;
  height: 64rpx;
}

.icon-primary {
  color: var(--primary-color);
}

.icon-secondary {
  color: var(--text-secondary);
}
