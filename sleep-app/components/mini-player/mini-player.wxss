.mini-player {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 120rpx;
  height: 100rpx;
  background: #FFFFFF;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(168, 197, 232, 0.2);
  transform: translateY(200rpx);
  opacity: 0;
  transition: all 0.3s ease;
  z-index: 100;
}

.mini-player.show {
  transform: translateY(0);
  opacity: 1;
}

.cover {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 20rpx;
}

.info {
  flex: 1;
  overflow: hidden;
}

.name {
  font-size: 28rpx;
  color: #3A3A55;
  font-weight: 500;
}

.status {
  font-size: 24rpx;
  margin-top: 4rpx;
}

.controls {
  display: flex;
  align-items: center;
}

.btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #A8C5E8;
}

.btn.close {
  color: #9A9AB0;
  font-size: 28rpx;
}
