<view class="training-page theme-{{theme}}">
  <view class="background"></view>
  
  <view class="content">
    <view class="animation-area">
      <view class="breath-circle {{breathStatus}}">
        <view class="inner-circle">
          <icons name="breath" size="80" color="white" />
        </view>
        <view class="breath-text">{{breathText}}</view>
      </view>
    </view>

    <view class="step-info">
      <view class="step-name">{{currentStep.name}}</view>
      <view class="step-instruction">{{currentStep.instruction}}</view>
    </view>

    <view class="timer-display">
      <view class="timer-value">{{timerDisplay}}</view>
      <view class="timer-label">
        <text>第{{currentStepIndex + 1}}步 / 共{{totalSteps}}步</text>
      </view>
    </view>

    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progress}}%;"></view>
    </view>

    <view class="controls">
      <view class="control-btn secondary" bindtap="endTraining">
        <text>结束</text>
      </view>
      <view class="control-btn primary" bindtap="togglePause">
        <text>{{isPaused ? '继续' : '暂停'}}</text>
      </view>
    </view>
  </view>
</view>

<view class="complete-modal {{showComplete ? 'show' : ''}}">
  <view class="modal-content">
    <view class="complete-icon">
      <icons name="check" size="60" color="primary" />
    </view>
    <view class="complete-title">训练完成</view>
    <view class="complete-stats">
      <view class="stat-item">
        <text class="stat-value">{{completedDuration}}</text>
        <text class="stat-label">分钟</text>
      </view>
    </view>
    <view class="complete-message">{{training.name}}</view>
    <view class="complete-actions">
      <button class="btn-secondary" bindtap="backToList">返回列表</button>
      <button class="btn-primary" bindtap="restartTraining">再来一次</button>
    </view>
  </view>
</view>
