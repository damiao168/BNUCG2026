.training-page {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--bg-page);
  transition: background-color 0.3s ease;
}

.background {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-page);
}

.content {
  position: relative;
  z-index: 1;
  width: 100%;
  padding: 60rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.animation-area {
  margin-bottom: 60rpx;
}

.breath-circle {
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-card);
  transition: all 4s ease-in-out;
  position: relative;
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(4rpx);
}

.breath-circle.inhale {
  transform: scale(1.2);
  background: rgba(90, 125, 154, 0.15);
}

.breath-circle.exhale {
  transform: scale(1);
  background: var(--bg-card);
}

.inner-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: var(--primary-color);
  display: flex;
  align-items: center;
  justify-content: center;
}

.breath-text {
  position: absolute;
  font-size: 36rpx;
  color: var(--text-primary);
  font-weight: 500;
  transition: color 0.3s ease;
}

.step-info {
  text-align: center;
  margin-bottom: 40rpx;
}

.step-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  transition: color 0.3s ease;
}

.step-instruction {
  font-size: 28rpx;
  color: var(--text-secondary);
  max-width: 500rpx;
  transition: color 0.3s ease;
}

.timer-display {
  text-align: center;
  margin-bottom: 30rpx;
}

.timer-value {
  font-size: 72rpx;
  font-weight: 600;
  color: var(--primary-color);
  font-variant-numeric: tabular-nums;
  transition: color 0.3s ease;
}

.timer-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
  transition: color 0.3s ease;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(90, 125, 154, 0.1);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 50rpx;
}

.progress-fill {
  height: 100%;
  background: var(--primary-color);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.controls {
  display: flex;
  gap: 30rpx;
  width: 100%;
}

.control-btn {
  flex: 1;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.control-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.control-btn.primary {
  background: var(--primary-color);
  color: #FFFFFF;
}

.control-btn.secondary {
  background: var(--bg-card);
  color: var(--text-secondary);
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(4rpx);
  transition: background-color 0.3s ease, color 0.3s ease, box-shadow 0.3s ease;
}

.complete-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.2s ease;
}

.complete-modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  background: var(--bg-card);
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  width: 80%;
  max-width: 600rpx;
  transform: scale(0.95);
  transition: transform 0.2s ease, background-color 0.3s ease;
  backdrop-filter: blur(4rpx);
}

.complete-modal.show .modal-content {
  transform: scale(1);
}

.complete-icon {
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.complete-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 30rpx;
  transition: color 0.3s ease;
}

.complete-stats {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--primary-color);
  transition: color 0.3s ease;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-left: 8rpx;
  transition: color 0.3s ease;
}

.complete-message {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 40rpx;
  transition: color 0.3s ease;
}

.complete-actions {
  display: flex;
  gap: 20rpx;
}

.complete-actions button {
  flex: 1;
}
