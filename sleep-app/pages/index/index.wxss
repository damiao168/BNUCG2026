.page-container {
  min-height: 100vh;
  background-color: var(--bg-page);
  transition: background-color 0.3s ease;
}

.header {
  padding: 40rpx 0 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.greeting {
  margin-bottom: 10rpx;
}

.theme-toggle {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(4rpx);
  transition: all 0.2s ease;
}

.theme-toggle:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.theme-icon {
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.theme-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.time-greeting {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.date {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.start-section {
  margin: 40rpx 0;
}

.start-btn {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #7CB89E 0%, #5A9E7A 100%);
  border-radius: 24rpx;
  padding: 36rpx 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(92, 158, 122, 0.25);
  transition: all 0.2s ease;
}

.start-btn:active {
  transform: scale(0.98);
  opacity: 0.95;
}

.start-icon {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
}

.start-content {
  flex: 1;
}

.start-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.start-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.feature-section {
  margin: 40rpx 0;
}

.feature-grid {
  display: flex;
  gap: 20rpx;
}

.feature-card {
  flex: 1;
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(4rpx);
  transition: all 0.2s ease;
}

.feature-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.feature-icon {
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: rgba(90, 125, 154, 0.08);
}

.feature-info {
  flex: 1;
}

.feature-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.feature-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.feature-arrow {
  align-self: center;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-more {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.audio-scroll {
  margin: 0 -32rpx;
  padding: 0 32rpx;
}

.audio-list {
  display: flex;
  gap: 20rpx;
  padding-right: 32rpx;
}

.audio-item {
  flex-shrink: 0;
  width: 220rpx;
}

.audio-cover {
  width: 220rpx;
  height: 220rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  display: block;
}

.audio-name {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.audio-duration {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.training-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.training-card {
  padding: 28rpx;
  background: var(--bg-card);
  backdrop-filter: blur(4rpx);
}

.training-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.training-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  background: rgba(90, 125, 154, 0.08);
}

.training-icon.breath {
  background: rgba(141, 123, 104, 0.1);
}

.training-icon.body {
  background: rgba(200, 162, 200, 0.1);
}

.training-info {
  flex: 1;
}

.training-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.training-meta {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.training-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}
