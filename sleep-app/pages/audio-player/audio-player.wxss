.player-page {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-page);
  transition: background-color 0.3s ease;
}

.background {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-page);
}

.overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--overlay-bg);
  transition: background 0.3s ease;
}

.content {
  position: relative;
  z-index: 1;
  width: 100%;
  padding: 60rpx 60rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-bar {
  position: absolute;
  top: 40rpx;
  left: 40rpx;
  right: 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 10;
}

.back-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-card);
  border-radius: 50rpx;
  backdrop-filter: blur(10rpx);
  transform: rotate(180deg);
}

.cover-wrapper {
  width: 400rpx;
  height: 400rpx;
  margin-bottom: 60rpx;
  margin-top: 100rpx;
}

.cover {
  width: 100%;
  height: 100%;
  border-radius: 40rpx;
  background: var(--bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(4rpx);
}

.cover.playing {
  animation: breathe 4s ease-in-out infinite;
}

.audio-info {
  text-align: center;
  margin-bottom: 50rpx;
}

.audio-name {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.audio-category {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.progress-section {
  width: 100%;
  margin-bottom: 50rpx;
}

.progress-bar {
  margin-bottom: 16rpx;
}

.slider {
  margin: 0;
}

.time-display {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 60rpx;
  margin-bottom: 50rpx;
}

.control-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-btn {
  width: 120rpx;
  height: 120rpx;
  background: var(--primary-color);
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 30rpx rgba(90, 125, 154, 0.3);
}

.function-bar {
  display: flex;
  justify-content: space-around;
  width: 100%;
  margin-bottom: 40rpx;
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.function-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.volume-section {
  display: flex;
  align-items: center;
  width: 100%;
  gap: 20rpx;
}

.volume-slider {
  flex: 1;
}

.timer-picker,
.mix-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.2s ease;
}

.timer-picker.show,
.mix-panel.show {
  opacity: 1;
  visibility: visible;
}

.picker-content,
.panel-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  transform: translateY(100%);
  transition: transform 0.2s ease;
  backdrop-filter: blur(4rpx);
}

.timer-picker.show .picker-content,
.mix-panel.show .panel-content {
  transform: translateY(0);
}

.picker-title,
.panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 30rpx;
}

.picker-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.picker-option {
  flex: 1;
  min-width: calc(50% - 10rpx);
  padding: 24rpx;
  background: rgba(90, 125, 154, 0.06);
  border-radius: 16rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: all 0.2s ease;
}

.picker-option.active {
  background: var(--primary-color);
  color: #FFFFFF;
}

.mix-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.mix-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.mix-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.mix-name {
  font-size: 28rpx;
  color: var(--text-primary);
}

.mix-slider {
  width: 100%;
}

.panel-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.panel-actions button {
  flex: 1;
}

@keyframes breathe {
  0%, 100% { transform: scale(1); opacity: 0.8; }
  50% { transform: scale(1.03); opacity: 1; }
}
