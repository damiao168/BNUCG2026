<view class="player-page theme-{{theme}}">
  <view class="background"></view>
  <view class="overlay"></view>
  
  <view class="content">
    <view class="header-bar">
      <view class="back-btn" bindtap="goBack">
        <icons name="arrow-right" size="32" color="primary" />
      </view>
    </view>

    <view class="cover-wrapper">
      <view class="cover {{isPlaying ? 'playing' : ''}}">
        <icons name="music" size="120" color="secondary" />
      </view>
    </view>

    <view class="audio-info">
      <view class="audio-name">{{audio.name}}</view>
      <view class="audio-category">{{audio.categoryName}}</view>
    </view>

    <view class="progress-section">
      <view class="progress-bar">
        <slider 
          class="slider"
          min="0" 
          max="{{duration}}" 
          value="{{currentTime}}"
          block-size="16"
          activeColor="var(--primary-color)"
          backgroundColor="var(--disabled-color)"
          bindchange="onSeek"
          bindchanging="onSeeking"
        />
      </view>
      <view class="time-display">
        <text>{{currentTimeText}}</text>
        <text>{{durationText}}</text>
      </view>
    </view>

    <view class="controls">
      <view class="control-btn" bindtap="playPrev">
        <icons name="history" size="36" color="secondary" />
      </view>
      <view class="play-btn" bindtap="togglePlay">
        <icons name="{{isPlaying ? 'pause' : 'play'}}" size="48" color="white" />
      </view>
      <view class="control-btn" bindtap="playNext">
        <icons name="history" size="36" color="secondary" />
      </view>
    </view>

    <view class="function-bar">
      <view class="function-item" bindtap="togglePlayMode">
        <icons name="settings" size="40" color="secondary" />
        <text class="function-text">{{playModeText}}</text>
      </view>
      <view class="function-item" bindtap="showTimerPicker">
        <icons name="volume" size="40" color="secondary" />
        <text class="function-text">{{timerText}}</text>
      </view>
      <view class="function-item" bindtap="showMixPanel">
        <icons name="settings" size="40" color="secondary" />
        <text class="function-text">混音</text>
      </view>
      <view class="function-item" bindtap="toggleFavorite">
        <icons name="favorite" size="40" color="{{isFavorite ? 'accent2' : 'secondary'}}" />
        <text class="function-text">{{isFavorite ? '已收藏' : '收藏'}}</text>
      </view>
    </view>

    <view class="volume-section">
      <icons name="volume" size="28" color="secondary" />
      <slider 
        class="volume-slider"
        min="0" 
        max="100" 
        value="{{volume}}"
        block-size="14"
        activeColor="var(--primary-color)"
        backgroundColor="var(--disabled-color)"
        bindchange="onVolumeChange"
      />
      <icons name="volume" size="32" color="primary" />
    </view>
  </view>
</view>

<view class="timer-picker {{showTimerPicker ? 'show' : ''}}" bindtap="hideTimerPicker">
  <view class="picker-content" catchtap="">
    <view class="picker-title">定时关闭</view>
    <view class="picker-options">
      <view 
        class="picker-option {{timerValue === item.value ? 'active' : ''}}"
        wx:for="{{timerOptions}}"
        wx:key="value"
        bindtap="setTimer"
        data-value="{{item.value}}"
      >
        {{item.label}}
      </view>
    </view>
  </view>
</view>

<view class="mix-panel {{showMixPanel ? 'show' : ''}}" bindtap="hideMixPanel">
  <view class="panel-content" catchtap="">
    <view class="panel-title">混音设置</view>
    <view class="mix-list">
      <view class="mix-item" wx:for="{{mixSounds}}" wx:key="id">
        <view class="mix-info">
          <text class="mix-name">{{item.name}}</text>
          <icons name="volume" size="28" color="secondary" />
        </view>
        <slider 
          class="mix-slider"
          min="0" 
          max="100" 
          value="{{item.volume}}"
          block-size="14"
          activeColor="var(--primary-color)"
          backgroundColor="var(--disabled-color)"
          data-index="{{index}}"
          bindchange="onMixVolumeChange"
        />
      </view>
    </view>
    <view class="panel-actions">
      <button class="btn-secondary" bindtap="clearMix">清除全部</button>
      <button class="btn-primary" bindtap="applyMix">应用混音</button>
    </view>
  </view>
</view>
