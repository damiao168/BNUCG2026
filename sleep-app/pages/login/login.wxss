.login-page {
  min-height: 100vh;
  background-color: var(--bg-page);
  transition: background-color 0.3s ease;
}

.login-container {
  padding: 80rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--accent-color-2) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(90, 125, 154, 0.2);
}

.title {
  font-size: 44rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.login-form {
  width: 100%;
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  padding: 0;
  background: transparent;
  border: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.avatar-btn::after {
  border: none;
}

.avatar-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: var(--bg-card);
  box-shadow: var(--shadow-card);
}

.avatar-tip {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.privacy-section {
  width: 100%;
  margin-bottom: 40rpx;
}

.privacy-label {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.privacy-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.privacy-link {
  font-size: 26rpx;
  color: var(--primary-color);
}

.login-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, var(--success-color) 0%, var(--success-color-dark) 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(124, 184, 158, 0.3);
  transition: all 0.2s ease;
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  transform: scale(0.98);
  opacity: 0.95;
}

.login-btn.loading {
  opacity: 0.7;
}

.skip-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: transparent;
  color: var(--text-secondary);
  font-size: 30rpx;
  border-radius: 48rpx;
  border: none;
}

.skip-btn::after {
  border: none;
}
