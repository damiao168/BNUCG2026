<view class="page-container theme-{{theme}}">
  <view class="container">
    <view class="header">
      <view class="header-title">放松训练</view>
      <view class="header-desc">舒缓身心，释放压力</view>
    </view>

    <scroll-view class="category-scroll" scroll-x>
      <view class="category-list">
        <view 
          class="category-item {{currentCategory === item.id ? 'active' : ''}}"
          wx:for="{{categories}}"
          wx:key="id"
          bindtap="switchCategory"
          data-id="{{item.id}}"
        >
          <view class="category-icon">
            <icons name="{{item.iconType}}" size="28" color="{{currentCategory === item.id ? 'white' : 'secondary'}}" />
          </view>
          <text class="category-name">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>

    <view class="training-list">
      <view 
        class="training-card card"
        wx:for="{{trainingList}}"
        wx:key="id"
        bindtap="startTraining"
        data-training="{{item}}"
      >
        <view class="training-header">
          <view class="training-icon {{item.iconType}}">
            <icons name="{{item.iconType}}" size="40" color="primary" />
          </view>
          <view class="training-info">
            <view class="training-name">{{item.name}}</view>
            <view class="training-meta">
              <text>{{item.duration}}分钟</text>
              <text class="dot">·</text>
              <text>{{item.level}}</text>
            </view>
          </view>
          <view class="training-arrow">
            <icons name="arrow-right" size="28" color="secondary" />
          </view>
        </view>
        <view class="training-desc">{{item.description}}</view>
        <view class="training-tags">
          <text class="tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
