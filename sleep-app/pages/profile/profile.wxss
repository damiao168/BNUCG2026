.page-container {
  min-height: 100vh;
  background-color: var(--bg-page);
  transition: background-color 0.3s ease;
}

.header {
  padding: 40rpx 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background: var(--primary-color);
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 60rpx;
}

.user-detail {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.user-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.header-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
}

.section {
  margin-top: 40rpx;
}

.section-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.menu-card {
  padding: 0;
  background: var(--bg-card);
  backdrop-filter: blur(4rpx);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border-color);
  transition: background-color 0.2s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: rgba(90, 125, 154, 0.05);
}

.menu-icon {
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
}

.menu-value {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-right: 10rpx;
}

.menu-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
}

.footer {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.footer-text {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.2s ease;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 500rpx;
  transform: scale(0.95);
  transition: transform 0.2s ease;
  backdrop-filter: blur(4rpx);
}

.modal.show .modal-content {
  transform: scale(1);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-body {
  margin-bottom: 30rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-actions button {
  flex: 1;
}
