.page-container {
  min-height: 100vh;
  background-color: var(--bg-page);
  transition: background-color 0.3s ease;
}

.search-bar {
  margin-bottom: 24rpx;
}

.search-input {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(4rpx);
}

.search-icon {
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-input input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.search-placeholder {
  color: var(--text-secondary);
}

.category-scroll {
  margin: 0 -32rpx;
  padding: 0 32rpx;
  margin-bottom: 30rpx;
}

.category-list {
  display: flex;
  gap: 16rpx;
  padding-right: 32rpx;
}

.category-item {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  background: var(--bg-card);
  border-radius: 50rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all 0.2s ease;
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(4rpx);
}

.category-item.active {
  background: var(--primary-color);
  color: #FFFFFF;
}

.category-icon {
  margin-right: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.category-name {
  font-weight: 500;
}

.audio-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.audio-card {
  width: calc(50% - 10rpx);
  background: var(--bg-card);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(4rpx);
  position: relative;
  transition: all 0.2s ease;
}

.audio-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.audio-cover {
  width: 100%;
  height: 200rpx;
  border-radius: 20rpx 20rpx 0 0;
}

.audio-info {
  padding: 20rpx;
}

.audio-name {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 10rpx;
}

.audio-meta {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.favorite-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background: var(--bg-card);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4rpx);
  transition: all 0.2s ease;
}

.favorite-btn.active {
  background: rgba(200, 162, 200, 0.15);
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}
