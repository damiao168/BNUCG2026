<view class="page-container theme-{{theme}}">
  <view class="container">
    <view class="search-bar">
      <view class="search-input">
        <view class="search-icon">
          <icons name="settings" size="32" color="secondary" />
        </view>
        <input 
          placeholder="搜索音频" 
          value="{{searchText}}"
          bindinput="onSearch"
          placeholder-class="search-placeholder"
        />
      </view>
    </view>

    <scroll-view class="category-scroll" scroll-x>
      <view class="category-list">
        <view 
          class="category-item {{currentCategory === item.id ? 'active' : ''}}"
          wx:for="{{categories}}"
          wx:key="id"
          bindtap="switchCategory"
          data-id="{{item.id}}"
        >
          <view class="category-icon">
            <icons name="{{item.iconType}}" size="28" color="{{currentCategory === item.id ? 'white' : 'secondary'}}" />
          </view>
          <text class="category-name">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>

    <view class="audio-grid">
      <view 
        class="audio-card"
        wx:for="{{audioList}}"
        wx:key="id"
        bindtap="playAudio"
        data-audio="{{item}}"
      >
        <image class="audio-cover" src="{{item.cover}}" mode="aspectFill"></image>
        <view class="audio-info">
          <view class="audio-name ellipsis">{{item.name}}</view>
          <view class="audio-meta">
            <text class="audio-duration">{{item.durationText}}</text>
            <text class="audio-category">{{item.categoryName}}</text>
          </view>
        </view>
        <view class="favorite-btn {{item.isFavorite ? 'active' : ''}}" catchtap="toggleFavorite" data-audio="{{item}}">
          <icons name="favorite" size="28" color="{{item.isFavorite ? 'accent2' : 'secondary'}}" />
        </view>
      </view>
    </view>

    <view class="empty" wx:if="{{audioList.length === 0}}">
      <view class="empty-icon">
        <icons name="music" size="80" color="secondary" />
      </view>
      <text class="empty-text">暂无音频</text>
    </view>
  </view>

  <mini-player 
    audio="{{currentAudio}}" 
    show="{{showMiniPlayer}}"
    bind:tap="goToPlayer"
    bind:close="closePlayer"
  />
</view>
