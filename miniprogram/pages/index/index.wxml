<view class="container">
  <view class="card">
    <view class="flex justify-between align-center">
      <view>
        <text class="text-muted">今日</text>
        <view class="mt-20">
          <text class="text-primary" style="font-size: 48rpx; font-weight: bold;">{{currentDate}}</text>
        </view>
      </view>
      <view class="text-right">
        <text class="text-muted">本周打卡</text>
        <view class="mt-20">
          <text style="font-size: 48rpx; font-weight: bold;">{{weeklyCount}}</text>
          <text class="text-muted">/7天</text>
        </view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="flex justify-center align-center" style="height: 200rpx;">
      <button class="btn-primary" style="width: 300rpx; font-size: 36rpx;" bindtap="goToCheckin">
        立即打卡
      </button>
    </view>
  </view>

  <view class="card">
    <view class="flex justify-between align-center mb-20">
      <text style="font-size: 32rpx; font-weight: 500;">最近打卡</text>
      <text class="text-muted" bindtap="goToMine">查看全部 ></text>
    </view>
    <view wx:if="{{recentRecords.length > 0}}">
      <view wx:for="{{recentRecords}}" wx:key="id" class="flex justify-between align-center p-20" style="border-bottom: 1rpx solid #f0f0f0;">
        <view>
          <text style="font-size: 28rpx;">{{item.address}}</text>
          <view class="text-muted mt-10" style="font-size: 24rpx;">{{item.time}}</view>
        </view>
        <view class="text-success" style="font-size: 24rpx;">已打卡</view>
      </view>
    </view>
    <view wx:else class="flex justify-center align-center" style="height: 150rpx;">
      <text class="text-muted">暂无打卡记录</text>
    </view>
  </view>
</view>
