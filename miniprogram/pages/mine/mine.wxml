<view class="container">
  <view class="card">
    <view class="flex align-center">
      <view class="avatar">
        <text style="font-size: 48rpx;">👤</text>
      </view>
      <view class="ml-20">
        <view style="font-size: 36rpx; font-weight: 500;">打卡小助手</view>
        <view class="text-muted mt-10" style="font-size: 24rpx;">坚持打卡，记录每一天</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="flex justify-between">
      <view class="stat-item">
        <text style="font-size: 48rpx; font-weight: bold; color: #667eea;">{{totalCount}}</text>
        <view class="text-muted mt-10" style="font-size: 24rpx;">总打卡</view>
      </view>
      <view class="stat-item">
        <text style="font-size: 48rpx; font-weight: bold; color: #10b981;">{{monthCount}}</text>
        <view class="text-muted mt-10" style="font-size: 24rpx;">本月</view>
      </view>
      <view class="stat-item">
        <text style="font-size: 48rpx; font-weight: bold; color: #f59e0b;">{{weekCount}}</text>
        <view class="text-muted mt-10" style="font-size: 24rpx;">本周</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="flex justify-between align-center mb-20">
      <text style="font-size: 32rpx; font-weight: 500;">打卡记录</text>
      <text class="text-muted" bindtap="clearRecords" wx:if="{{records.length > 0}}">清空</text>
    </view>
    
    <view wx:if="{{records.length > 0}}">
      <view wx:for="{{records}}" wx:key="id" class="record-item">
        <view class="flex justify-between">
          <view>
            <view style="font-size: 30rpx; font-weight: 500;">{{item.address}}</view>
            <view class="text-muted mt-10" style="font-size: 24rpx;">
              {{item.date}} {{item.time}}
            </view>
            <view wx:if="{{item.remark}}" class="mt-10" style="font-size: 24rpx; color: #666;">
              备注: {{item.remark}}
            </view>
          </view>
          <view class="text-success" style="font-size: 24rpx;">✓</view>
        </view>
      </view>
    </view>
    
    <view wx:else class="flex justify-center align-center" style="height: 200rpx;">
      <text class="text-muted">暂无打卡记录</text>
    </view>
  </view>

  <view class="card">
    <view class="menu-item flex justify-between align-center" bindtap="exportRecords" wx:if="{{records.length > 0}}">
      <text>导出打卡记录</text>
      <text class="text-muted">></text>
    </view>
    <view class="menu-item flex justify-between align-center" bindtap="goToCheckin">
      <text>去打卡</text>
      <text class="text-muted">></text>
    </view>
  </view>
</view>
