<view class="container">
  <view class="card">
    <view style="text-align: center; padding: 40rpx 0;">
      <view class="text-muted" style="font-size: 28rpx;">当前位置</view>
      <view wx:if="{{location}}" class="mt-20" style="font-size: 36rpx; font-weight: 500;">
        {{location.address}}
      </view>
      <view wx:else class="mt-20 text-muted" style="font-size: 28rpx;">
        正在获取位置...
      </view>
      <view wx:if="{{location}}" class="mt-20 text-muted" style="font-size: 24rpx;">
        经度: {{location.longitude}} | 纬度: {{location.latitude}}
      </view>
    </view>
  </view>

  <view class="card">
    <view class="mb-20">
      <text style="font-size: 28rpx;">备注</text>
    </view>
    <textarea 
      class="textarea" 
      placeholder="添加打卡备注（可选）" 
      value="{{remark}}"
      bindinput="onRemarkInput"
      maxlength="200"
    ></textarea>
  </view>

  <view class="card">
    <view class="mb-20">
      <text style="font-size: 28rpx;">当前时间</text>
    </view>
    <view style="font-size: 48rpx; font-weight: bold; color: #667eea;">
      {{currentTime}}
    </view>
  </view>

  <view class="mt-40">
    <button 
      class="btn-primary" 
      bindtap="doCheckin" 
      disabled="{{!location || checking}}"
      style="opacity: {{location && !checking ? 1 : 0.5}}"
    >
      {{checking ? '打卡中...' : '确认打卡'}}
    </button>
  </view>
</view>
